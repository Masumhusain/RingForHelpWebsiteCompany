<%- layout("layouts/boilerplate.ejs") %>
<div class="container py-5 ">
  <!-- Page Heading -->
  <h1 class="text-center fw-bold mb-5">About Ring4Help</h1>

  <!-- About Section -->
  <div class="row align-items-center g-5">

    <!-- Left Image -->
    <div class="col-lg-6 text-center">
      <img src="/IMAGE/image2.jpg" alt="About Ring4Help" class="img-fluid rounded-4 shadow-lg">
    </div>

    <!-- Right Content -->
    <div class="col-lg-6">

      <h3 class="fw-bold mb-3">Our Mission</h3>
      <p class="text-muted mb-4">
        At Ring4Help, our mission is to connect people with trusted services across multiple domains.
        We aim to simplify the process of hiring professionals and ensure transparency, quality, and reliability.
      </p>

      <h3 class="fw-bold mb-3">Our Vision</h3>
      <p class="text-muted mb-4">
        We envision a world where every individual or business can access services with ease, confidence, and satisfaction.
        Our goal is to be the most trusted service marketplace in the region.
      </p>

      <h3 class="fw-bold mb-3">Why Choose Us?</h3>
      <ul class="list-unstyled text-muted">
        <li class="mb-2"><i class="fa-solid fa-check text-success me-2"></i>Trusted and Verified Service Providers</li>
        <li class="mb-2"><i class="fa-solid fa-check text-success me-2"></i>Easy Booking & Transparent Pricing</li>
        <li class="mb-2"><i class="fa-solid fa-check text-success me-2"></i>Customer Support & Satisfaction Guarantee</li>
        <li class="mb-2"><i class="fa-solid fa-check text-success me-2"></i>Professional & Experienced Teams</li>
      </ul>

      <a href="/services" class="btn btn-primary mt-4">Explore Services</a>

    </div>
  </div>
</div>

<style>
  

  p, li {
    font-size: 1rem;
  }

  .btn-primary {
    background: linear-gradient(90deg, #4a90e2, #357ab8);
    border: none;
    transition: all 0.3s ease;
  }

  .btn-primary:hover {
    background: linear-gradient(90deg, #357ab8, #4a90e2);
    transform: translateY(-2px);
  }

  img {
    transition: transform 0.3s ease;
  }

  img:hover {
    transform: scale(1.05);
  }
</style>
