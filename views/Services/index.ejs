<!-- views/services/index.ejs -->
<section class="r4h-services-wrapper">
  <div class="r4h-services">
    <div class="container">
      <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="r4h-section-title">Our Services</h2>
        <a href="/cart" class="cart-icon">
          <i class="fas fa-shopping-cart"></i>
          <span class="badge badge-danger" id="cartCount">
            <%= cartCount || 0 %>
          </span>
        </a>
      </div>

      <div class="r4h-service-grid">
        <% catagories.forEach(cat => { 
          if (!cat.items || cat.items.length === 0) return;
          const item = cat.items[0];
        %>
          <div class="r4h-service-card">
            <div class="r4h-service-img">
              <a href="/category/<%=cat.slug%>">
                <img src="<%= item.image %>" alt="<%= item.name %>">
              </a>
            </div>

            <div class="r4h-service-body">
              <span class="r4h-category"><%= cat.categoryName %></span>
              <h5><%= item.name %></h5>
              <p>Starting from ₹<%= item.sub %></p>
              
              <!-- Add to Cart Button -->
              <button class="btn btn-primary btn-sm add-to-cart" 
                      data-service-id="<%= item._id %>"
                      data-service-name="<%= item.name %>"
                      data-service-price="<%= item.sub %>">
                <i class="fas fa-plus-circle"></i> Add to Cart
              </button>
            </div>
          </div>
        <% }) %>
      </div>
    </div>
  </div>
</section>

<!-- Add to Cart JavaScript -->
<script>
  document.addEventListener('DOMContentLoaded', function() {
    const addToCartBtns = document.querySelectorAll('.add-to-cart');
    
    addToCartBtns.forEach(btn => {
      btn.addEventListener('click', function(e) {
        const serviceId = this.dataset.serviceId;
        const serviceName = this.dataset.serviceName;
        
        // Show quick quantity dialog
        showQuantityDialog(serviceId, serviceName);
      });
    });
    
    function showQuantityDialog(serviceId, serviceName) {
      // Create modal
      const modal = document.createElement('div');
      modal.className = 'modal fade';
      modal.id = 'quantityModal';
      modal.innerHTML = `
        <div class="modal-dialog">
          <div class="modal-content">
            <div class="modal-header">
              <h5>Add ${serviceName}</h5>
              <button type="button" class="close" data-dismiss="modal">&times;</button>
            </div>
            <div class="modal-body">
              <div class="form-group">
                <label>Duration (hours)</label>
                <input type="number" id="duration" class="form-control" value="1" min="1" max="8">
              </div>
              <div class="form-group">
                <label>Quantity</label>
                <input type="number" id="quantity" class="form-control" value="1" min="1" max="10">
              </div>
              <div class="form-group">
                <label>Special Notes (Optional)</label>
                <textarea id="notes" class="form-control" rows="2"></textarea>
              </div>
            </div>
            <div class="modal-footer">
              <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
              <button type="button" id="confirmAdd" class="btn btn-primary">Add to Cart</button>
            </div>
          </div>
        </div>
      `;
      
      document.body.appendChild(modal);
      
      // Show modal
      $(modal).modal('show');
      
      // Confirm button handler
      document.getElementById('confirmAdd').addEventListener('click', function() {
        const duration = document.getElementById('duration').value;
        const quantity = document.getElementById('quantity').value;
        const notes = document.getElementById('notes').value;
        
        addToCart(serviceId, duration, quantity, notes);
        
        // Close modal
        $(modal).modal('hide');
        setTimeout(() => modal.remove(), 500);
      });
      
      // Auto remove on hide
      $(modal).on('hidden.bs.modal', function() {
        modal.remove();
      });
    }
    
    function addToCart(serviceId, duration, quantity, notes) {
      fetch('/cart/add', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({ serviceId, duration, quantity, notes })
      })
      .then(response => response.json())
      .then(data => {
        if (data.success) {
          // Update cart count
          document.getElementById('cartCount').textContent = data.cartCount;
          
          // Show success toast
          showToast('Service added to cart!', 'success');
        } else {
          showToast('Error adding service', 'danger');
        }
      })
      .catch(error => {
        console.error('Error:', error);
        showToast('Error adding service', 'danger');
      });
    }
    
    function showToast(message, type) {
      const toast = document.createElement('div');
      toast.className = `toast-notification toast-${type}`;
      toast.innerHTML = `
        <div class="toast-content">
          <i class="fas ${type === 'success' ? 'fa-check-circle' : 'fa-exclamation-circle'}"></i>
          ${message}
        </div>
      `;
      document.body.appendChild(toast);
      
      setTimeout(() => {
        toast.classList.add('show');
        setTimeout(() => {
          toast.classList.remove('show');
          setTimeout(() => toast.remove(), 300);
        }, 3000);
      }, 100);
    }
  });
</script>

<style>
  .cart-icon {
    position: relative;
    font-size: 24px;
    color: #333;
    text-decoration: none;
  }
  
  .cart-icon .badge {
    position: absolute;
    top: -8px;
    right: -8px;
    font-size: 12px;
    padding: 3px 7px;
  }
  
  .add-to-cart {
    width: 100%;
    margin-top: 10px;
  }
  
  .toast-notification {
    position: fixed;
    top: 20px;
    right: 20px;
    z-index: 9999;
    padding: 15px 25px;
    border-radius: 8px;
    background: white;
    box-shadow: 0 4px 20px rgba(0,0,0,0.15);
    transform: translateX(120%);
    transition: transform 0.3s ease;
    max-width: 350px;
  }
  
  .toast-notification.show {
    transform: translateX(0);
  }
  
  .toast-notification.toast-success {
    border-left: 4px solid #28a745;
  }
  
  .toast-notification.toast-danger {
    border-left: 4px solid #dc3545;
  }
  
  .toast-content i {
    margin-right: 10px;
  }
  
  .toast-success i {
    color: #28a745;
  }
  
  .toast-danger i {
    color: #dc3545;
  }
</style>