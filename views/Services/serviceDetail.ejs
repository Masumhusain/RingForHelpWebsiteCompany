<%- layout("layouts/boilerplate.ejs") %>

<!-- Cart CSS -->
<link rel="stylesheet" href="/css/cart.css">

<div class="service-detail-page">
  <div class="container py-4">

    <!-- ===== BREADCRUMB ===== -->
    <nav aria-label="breadcrumb" class="mb-4">
      <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/" class="text-decoration-none">Home</a></li>
        <li class="breadcrumb-item"><a href="/services" class="text-decoration-none">Services</a></li>
        <li class="breadcrumb-item"><a href="/category/<%= categorySlug %>" class="text-decoration-none"><%= categorySlug %></a></li>
        <li class="breadcrumb-item active" aria-current="page"><%= service.name %></li>
      </ol>
    </nav>

    <div class="row g-4">

      <!-- ===== LEFT: IMAGE ===== -->
      <div class="col-lg-6">
        <div class="service-image-wrapper">
          <img src="<%= service.image %>" 
               alt="<%= service.name %>" 
               class="service-main-img img-fluid rounded-4 shadow-lg">
          
          <!-- Image Badge -->
          <div class="service-badge">
            <span class="badge bg-success"><i class="fas fa-check-circle"></i> Available Now</span>
          </div>
        </div>

        <!-- Thumbnails (if multiple images) -->
        <div class="service-thumbnails mt-3 d-flex gap-2">
          <img src="<%= service.image %>" alt="thumbnail" class="thumb-img active">
          <img src="<%= service.image %>" alt="thumbnail" class="thumb-img">
          <img src="<%= service.image %>" alt="thumbnail" class="thumb-img">
        </div>
      </div>

      <!-- ===== RIGHT: DETAILS ===== -->
      <div class="col-lg-6">
        <div class="service-details">

          <!-- Category -->
          <span class="service-category-badge">
            <i class="fas fa-tag"></i> <%= categorySlug || 'Service' %>
          </span>

          <!-- Title -->
          <h1 class="service-title"><%= service.name %></h1>

          <!-- Rating -->
          <div class="service-rating mb-3">
            <div class="stars">
              <i class="fas fa-star text-warning"></i>
              <i class="fas fa-star text-warning"></i>
              <i class="fas fa-star text-warning"></i>
              <i class="fas fa-star text-warning"></i>
              <i class="fas fa-star-half-alt text-warning"></i>
            </div>
            <span class="rating-text">4.8 (120+ reviews)</span>
          </div>

          <!-- Description -->
          <p class="service-description">
            <%= service.description || 'Professional service delivered with quality and reliability. Book now and get the best service experience.' %>
          </p>

          <!-- ===== PRICE CARD ===== -->
          <div class="price-card p-4 rounded-4 mb-4">
            <div class="row align-items-center">
              <div class="col-6">
                <span class="price-label">Starting from</span>
                <div class="price-amount">
                  ₹<%= service.sub || 0 %>
                  <span class="price-unit">/ hour</span>
                </div>
              </div>
              <div class="col-6 text-end">
                <span class="badge bg-success bg-opacity-10 text-success p-2">
                  <i class="fas fa-clock"></i> Instant Booking
                </span>
              </div>
            </div>
          </div>

          <!-- ===== SERVICE FEATURES ===== -->
          <div class="service-features row g-2 mb-4">
            <div class="col-6">
              <div class="feature-item">
                <i class="fas fa-shield-alt text-primary"></i>
                <span>Verified Professionals</span>
              </div>
            </div>
            <div class="col-6">
              <div class="feature-item">
                <i class="fas fa-money-bill-wave text-success"></i>
                <span>Best Price Guarantee</span>
              </div>
            </div>
            <div class="col-6">
              <div class="feature-item">
                <i class="fas fa-headset text-info"></i>
                <span>24/7 Support</span>
              </div>
            </div>
            <div class="col-6">
              <div class="feature-item">
                <i class="fas fa-calendar-check text-warning"></i>
                <span>Flexible Scheduling</span>
              </div>
            </div>
          </div>

          <!-- ===== DETAILS LIST ===== -->
          <div class="details-list rounded-4 p-3 mb-4">
            <div class="detail-row">
              <span class="detail-label"><i class="fas fa-tag"></i> Subscription</span>
              <span class="detail-value">₹<%= service.sub || 0 %></span>
            </div>
            <div class="detail-row">
              <span class="detail-label"><i class="fas fa-sync"></i> Renewal</span>
              <span class="detail-value">₹<%= service.renew || 0 %></span>
            </div>
            <div class="detail-row">
              <span class="detail-label"><i class="fas fa-file-contract"></i> Non-Contract</span>
              <span class="detail-value">₹<%= service.nonContract || 0 %></span>
            </div>
            <div class="detail-row">
              <span class="detail-label"><i class="fas fa-handshake"></i> Contract Type</span>
              <span class="detail-value"><%= service.contract || '-' %></span>
            </div>
          </div>

          <!-- ===== ADD TO CART ===== -->
          <div class="add-to-cart-card p-4 rounded-4">
            <h5 class="mb-3"><i class="fas fa-shopping-cart text-primary"></i> Book This Service</h5>

            <div class="row g-2">
              <!-- Duration -->
              <div class="col-md-4">
                <label class="form-label small fw-semibold">Duration</label>
                <select id="serviceDuration" class="form-select">
                  <option value="1">1 Hour</option>
                  <option value="2">2 Hours</option>
                  <option value="3">3 Hours</option>
                  <option value="4">4 Hours</option>
                  <option value="5">5 Hours</option>
                  <option value="6">6 Hours</option>
                  <option value="7">7 Hours</option>
                  <option value="8">8 Hours</option>
                </select>
              </div>

              <!-- Quantity -->
              <div class="col-md-3">
                <label class="form-label small fw-semibold">Quantity</label>
                <select id="serviceQuantity" class="form-select">
                  <option value="1">1</option>
                  <option value="2">2</option>
                  <option value="3">3</option>
                  <option value="4">4</option>
                  <option value="5">5</option>
                </select>
              </div>

              <!-- Total -->
              <div class="col-md-5">
                <label class="form-label small fw-semibold">Total</label>
                <div class="total-price-box">
                  <span id="serviceTotalPrice">₹<%= service.sub || 0 %></span>
                </div>
              </div>
            </div>

            <!-- Notes -->
            <div class="mt-2">
              <input type="text" id="serviceNotes" class="form-control" 
                     placeholder="Any special requests? (Optional)">
            </div>

            <!-- Buttons -->
            <div class="d-grid gap-2 mt-3">
              <button class="btn btn-primary btn-lg add-to-cart-detail" 
                      data-service-id="<%= service._id %>"
                      data-service-name="<%= service.name %>"
                      data-category-slug="<%= categorySlug %>"
                      data-service-slug="<%= service.slug %>"
                      data-image="<%= service.image %>"
                      data-price="<%= service.sub || 0 %>">
                <i class="fas fa-plus-circle"></i> Add to Cart
              </button>
              <a href="/cart" class="btn btn-outline-secondary">
                <i class="fas fa-shopping-cart"></i> View Cart
              </a>
            </div>
          </div>

        </div>
      </div>
    </div>

  </div>
</div>

<!-- ============================================ -->
<!-- ===== STYLES ===== -->
<!-- ============================================ -->

<style>
  /* ===== PAGE ===== */
  .service-detail-page {
    background: #f8f9fa;
    min-height: 100vh;
  }

  .container {
    max-width: 1200px;
  }

  /* ===== BREADCRUMB ===== */
  .breadcrumb {
    background: transparent;
    padding: 0;
    margin: 0;
  }

  .breadcrumb-item a {
    color: #007bff;
    transition: color 0.3s;
  }

  .breadcrumb-item a:hover {
    color: #0056b3;
  }

  .breadcrumb-item.active {
    color: #6c757d;
  }

  /* ===== IMAGE ===== */
  .service-image-wrapper {
    position: relative;
    overflow: hidden;
    border-radius: 16px;
  }

  .service-main-img {
    width: 100%;
    height: 400px;
    object-fit: cover;
    transition: transform 0.5s;
  }

  .service-main-img:hover {
    transform: scale(1.02);
  }

  .service-badge {
    position: absolute;
    top: 20px;
    left: 20px;
  }

  .service-badge .badge {
    padding: 8px 16px;
    font-size: 14px;
    border-radius: 30px;
  }

  .service-thumbnails {
    overflow-x: auto;
    padding-bottom: 5px;
  }

  .thumb-img {
    width: 80px;
    height: 60px;
    object-fit: cover;
    border-radius: 8px;
    border: 2px solid transparent;
    cursor: pointer;
    transition: all 0.3s;
  }

  .thumb-img:hover {
    border-color: #007bff;
  }

  .thumb-img.active {
    border-color: #007bff;
  }

  /* ===== SERVICE DETAILS ===== */
  .service-details {
    background: white;
    padding: 30px;
    border-radius: 16px;
    box-shadow: 0 2px 20px rgba(0,0,0,0.06);
  }

  .service-category-badge {
    display: inline-block;
    background: #e9ecef;
    color: #495057;
    padding: 4px 16px;
    border-radius: 30px;
    font-size: 13px;
    font-weight: 500;
    margin-bottom: 12px;
  }

  .service-title {
    font-size: 2.2rem;
    font-weight: 700;
    color: #1a1a2e;
    margin-bottom: 8px;
  }

  .service-rating {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .stars {
    display: flex;
    gap: 2px;
  }

  .stars i {
    font-size: 16px;
  }

  .rating-text {
    color: #6c757d;
    font-size: 14px;
  }

  .service-description {
    color: #6c757d;
    font-size: 1rem;
    line-height: 1.7;
    margin-bottom: 20px;
  }

  /* ===== PRICE CARD ===== */
  .price-card {
    background: linear-gradient(135deg, #f8f9fa, #e9ecef);
    border: 1px solid #e0e0e0;
  }

  .price-label {
    font-size: 14px;
    color: #6c757d;
  }

  .price-amount {
    font-size: 2rem;
    font-weight: 700;
    color: #28a745;
  }

  .price-unit {
    font-size: 1rem;
    font-weight: 400;
    color: #6c757d;
  }

  /* ===== FEATURES ===== */
  .service-features {
    margin-bottom: 16px;
  }

  .feature-item {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 12px;
    background: #f8f9fa;
    border-radius: 8px;
    font-size: 13px;
    font-weight: 500;
  }

  .feature-item i {
    font-size: 16px;
  }

  /* ===== DETAILS LIST ===== */
  .details-list {
    background: #f8f9fa;
    border: 1px solid #e9ecef;
  }

  .detail-row {
    display: flex;
    justify-content: space-between;
    padding: 8px 0;
    border-bottom: 1px solid #e9ecef;
  }

  .detail-row:last-child {
    border-bottom: none;
  }

  .detail-label {
    color: #6c757d;
    font-size: 14px;
  }

  .detail-label i {
    margin-right: 6px;
    width: 18px;
  }

  .detail-value {
    font-weight: 600;
    color: #1a1a2e;
  }

  /* ===== ADD TO CART CARD ===== */
  .add-to-cart-card {
    background: #f8f9fa;
    border: 2px solid #e9ecef;
  }

  .add-to-cart-card h5 {
    color: #1a1a2e;
  }

  .form-select {
    border-radius: 8px;
    border: 2px solid #e0e0e0;
    padding: 8px 12px;
    font-size: 14px;
  }

  .form-select:focus {
    border-color: #007bff;
    box-shadow: 0 0 0 3px rgba(0,123,255,0.15);
  }

  .form-control {
    border-radius: 8px;
    border: 2px solid #e0e0e0;
    padding: 8px 12px;
    font-size: 14px;
  }

  .form-control:focus {
    border-color: #007bff;
    box-shadow: 0 0 0 3px rgba(0,123,255,0.15);
  }

  .total-price-box {
    background: white;
    border-radius: 8px;
    padding: 8px 16px;
    border: 2px solid #e0e0e0;
    height: 100%;
    display: flex;
    align-items: center;
  }

  .total-price-box span {
    font-size: 1.3rem;
    font-weight: 700;
    color: #28a745;
  }

  .btn-primary {
    background: #007bff;
    border: none;
    padding: 12px 20px;
    border-radius: 8px;
    font-weight: 600;
    transition: all 0.3s;
  }

  .btn-primary:hover {
    background: #0056b3;
    transform: translateY(-2px);
    box-shadow: 0 4px 20px rgba(0,123,255,0.3);
  }

  .btn-outline-secondary {
    border: 2px solid #6c757d;
    color: #6c757d;
    border-radius: 8px;
    padding: 10px 20px;
    font-weight: 600;
    transition: all 0.3s;
  }

  .btn-outline-secondary:hover {
    background: #6c757d;
    color: white;
  }

  /* ===== SIMILAR SERVICES ===== */
  .similar-services {
    border-top: 1px solid #e9ecef;
  }

  .similar-card {
    background: white;
    padding: 10px;
    border-radius: 12px;
    text-align: center;
    transition: all 0.3s;
    cursor: pointer;
  }

  .similar-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 4px 20px rgba(0,0,0,0.1);
  }

  .similar-card img {
    width: 100%;
    height: 100px;
    object-fit: cover;
    border-radius: 8px;
  }

  .similar-card h6 {
    font-size: 14px;
    font-weight: 600;
    margin-bottom: 2px;
  }

  .similar-card small {
    font-size: 12px;
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 992px) {
    .service-details {
      padding: 20px;
    }

    .service-title {
      font-size: 1.8rem;
    }

    .price-amount {
      font-size: 1.8rem;
    }

    .service-main-img {
      height: 300px;
    }
  }

  @media (max-width: 768px) {
    .service-details {
      padding: 16px;
    }

    .service-title {
      font-size: 1.5rem;
    }

    .service-main-img {
      height: 250px;
    }

    .price-amount {
      font-size: 1.5rem;
    }

    .add-to-cart-card .row .col-md-4,
    .add-to-cart-card .row .col-md-3,
    .add-to-cart-card .row .col-md-5 {
      flex: 0 0 100%;
      max-width: 100%;
      margin-bottom: 8px;
    }

    .total-price-box {
      height: auto;
      padding: 10px 16px;
    }

    .feature-item {
      font-size: 12px;
      padding: 6px 10px;
    }

    .service-features .col-6 {
      padding: 0 4px;
    }
  }

  @media (max-width: 576px) {
    .service-main-img {
      height: 200px;
    }

    .service-title {
      font-size: 1.3rem;
    }

    .price-amount {
      font-size: 1.3rem;
    }

    .breadcrumb {
      font-size: 13px;
    }

    .thumb-img {
      width: 60px;
      height: 45px;
    }
  }

  /* ===== ANIMATIONS ===== */
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .service-details {
    animation: fadeInUp 0.6s ease;
  }

  .service-image-wrapper {
    animation: fadeInUp 0.8s ease;
  }
</style>

<!-- ============================================ -->
<!-- ===== SCRIPTS ===== -->
<!-- ============================================ -->

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const durationSelect = document.getElementById('serviceDuration');
    const quantitySelect = document.getElementById('serviceQuantity');
    const totalPriceDisplay = document.getElementById('serviceTotalPrice');
    const basePrice = <%= service.sub || 0 %>;

    // ===== UPDATE TOTAL PRICE =====
    function updateTotalPrice() {
      const duration = parseInt(durationSelect.value) || 1;
      const quantity = parseInt(quantitySelect.value) || 1;
      const total = basePrice * duration * quantity;
      totalPriceDisplay.textContent = '₹' + total;
    }

    durationSelect.addEventListener('change', updateTotalPrice);
    quantitySelect.addEventListener('change', updateTotalPrice);

    // ===== ADD TO CART =====
    const addToCartBtn = document.querySelector('.add-to-cart-detail');
    if (addToCartBtn) {
      addToCartBtn.addEventListener('click', function(e) {
        e.preventDefault();

        // Show loading state
        const originalText = this.innerHTML;
        this.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Adding...';
        this.disabled = true;

        const serviceId = this.dataset.serviceId;
        const serviceName = this.dataset.serviceName;
        const categorySlug = this.dataset.categorySlug;
        const serviceSlug = this.dataset.serviceSlug;
        const image = this.dataset.image || '';
        const price = parseFloat(this.dataset.price) || 0;
        const duration = parseInt(document.getElementById('serviceDuration').value) || 1;
        const quantity = parseInt(document.getElementById('serviceQuantity').value) || 1;
        const notes = document.getElementById('serviceNotes').value || '';

        fetch('/cart/add', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({
            serviceId: serviceId,
            serviceName: serviceName,
            categorySlug: categorySlug,
            serviceSlug: serviceSlug,
            image: image,
            price: price,
            duration: duration,
            quantity: quantity,
            notes: notes
          })
        })
        .then(response => response.json())
        .then(data => {
          if (data.success) {
            showToast('✅ ' + data.message, 'success');
            updateCartCount(data.cartCount);
            
            // Close any open modals automatically
            const modal = document.getElementById('quantityModal');
            if (modal) {
              modal.style.opacity = '0';
              modal.style.transition = 'opacity 0.3s ease';
              setTimeout(function() {
                if (modal && modal.parentElement) {
                  modal.remove();
                }
              }, 300);
            }
          } else {
            showToast('❌ ' + (data.error || 'Error adding to cart'), 'error');
          }
        })
        .catch(error => {
          console.error('Error:', error);
          showToast('❌ Network error. Please try again.', 'error');
        })
        .finally(() => {
          this.innerHTML = originalText;
          this.disabled = false;
        });
      });
    }

    // ===== THUMBNAIL CLICK =====
    document.querySelectorAll('.thumb-img').forEach(function(thumb) {
      thumb.addEventListener('click', function() {
        document.querySelectorAll('.thumb-img').forEach(function(t) {
          t.classList.remove('active');
        });
        this.classList.add('active');

        const mainImg = document.querySelector('.service-main-img');
        mainImg.src = this.src;
      });
    });
  });

  // ===== TOAST FUNCTION =====
  function showToast(message, type) {
    var container = document.querySelector('.toast-container');
    if (!container) {
      container = document.createElement('div');
      container.className = 'toast-container';
      container.style.cssText = `
        position: fixed;
        top: 20px;
        right: 20px;
        z-index: 99999;
        max-width: 380px;
        width: 100%;
      `;
      document.body.appendChild(container);
    }

    var toast = document.createElement('div');
    toast.style.cssText = `
      background: white;
      padding: 15px 20px;
      border-radius: 10px;
      box-shadow: 0 4px 20px rgba(0,0,0,0.15);
      margin-bottom: 10px;
      transform: translateX(120%);
      transition: transform 0.4s ease;
      border-left: 4px solid ${type === 'success' ? '#28a745' : '#dc3545'};
      display: flex;
      align-items: center;
      gap: 12px;
    `;

    var icon = type === 'success' ? '✅' : '❌';
    toast.innerHTML = `
      <span style="font-size: 20px;">${icon}</span>
      <span style="flex: 1; font-size: 14px;">${message}</span>
      <button onclick="this.parentElement.remove()" style="
        background: none;
        border: none;
        font-size: 20px;
        cursor: pointer;
        color: #999;
      ">&times;</button>
    `;

    container.appendChild(toast);

    setTimeout(function() {
      toast.style.transform = 'translateX(0)';
    }, 50);

    setTimeout(function() {
      toast.style.transform = 'translateX(120%)';
      setTimeout(function() {
        toast.remove();
      }, 400);
    }, 4000);
  }

  // ===== UPDATE CART COUNT =====
  function updateCartCount(count) {
    var badge = document.getElementById('cartCount');
    if (badge) {
      badge.textContent = count;
      badge.style.display = count > 0 ? 'inline' : 'none';
    }
    localStorage.setItem('cartCount', count);
  }

  // ===== INITIALIZE CART COUNT =====
  document.addEventListener('DOMContentLoaded', function() {
    const savedCount = localStorage.getItem('cartCount') || 0;
    const badge = document.getElementById('cartCount');
    if (badge) {
      badge.textContent = savedCount;
      badge.style.display = savedCount > 0 ? 'inline' : 'none';
    }
  });
</script>