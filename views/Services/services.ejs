<%- layout("layouts/boilerplate.ejs") %>

<!-- Cart CSS -->
<link rel="stylesheet" href="/css/cart.css">

<div class="container py-5">
  <h1 class="text-center mb-4">Our Services</h1>

  <% if (services && services.length > 0) { %>
    <% for (var i = 0; i < services.length; i++) { 
      var category = services[i]; %>
      <h2 class="category-title mt-5 mb-3">
        <i class="fas fa-tag"></i> <%= category.categoryName %>
      </h2>
      <div class="row g-3">
        <% for (var j = 0; j < category.items.length; j++) { 
          var item = category.items[j]; %>
          <div class="col-lg-2 col-md-3 col-sm-4 col-6">
            <div class="service-card shadow-sm p-2 rounded-3 bg-white">
              
              <!-- Image -->
              <div class="card-image mb-2">
                <a href="/service/<%= category.slug %>/<%= item.slug %>">
                  <img src="<%= item.image %>" 
                       alt="<%= item.name %>" 
                       class="img-fluid rounded-3"
                       style="width: 100%; height: 120px; object-fit: cover;">
                </a>
              </div>

              <!-- Text -->
              <div class="card-text text-center">
                <a href="/service/<%= category.slug %>/<%= item.slug %>" 
                   class="text-decoration-none text-dark">
                  <h6 class="fw-bold mb-1" style="font-size: 14px;"><%= item.name %></h6>
                  <p class="text-muted mb-2" style="font-size: 12px;">
                    ₹<%= item.sub || 0 %>/hr
                  </p>
                </a>
                
                <!-- ADD TO CART BUTTON -->
                <button class="btn btn-primary btn-sm add-to-cart w-100" 
                        data-service-id="<%= item._id %>"
                        data-service-name="<%= item.name %>"
                        data-category-slug="<%= category.slug %>"
                        data-service-slug="<%= item.slug %>"
                        data-image="<%= item.image %>"
                        data-price="<%= item.sub%>"
                        style="font-size: 12px;">
                  <i class="fas fa-plus-circle"></i> Add to Cart
                </button>
              </div>

            </div>
          </div>
        <% } %>
      </div>
    <% } %>
  <% } else { %>
    <div class="text-center py-5">
      <i class="fas fa-box-open" style="font-size: 60px; color: #ddd;"></i>
      <h3 class="mt-3">No Services Available</h3>
      <p class="text-muted">Check back later for new services.</p>
    </div>
  <% } %>
</div>

<!-- Cart JS -->
<script src="/js/cart.js"></script>
