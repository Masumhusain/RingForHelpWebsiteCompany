<%- layout("layouts/boilerplate.ejs") %>

<div class="profile-page">
  <div class="container py-4">

    <!-- Page Header -->
    <div class="profile-header mb-4">
      <h2><i class="fas fa-user-circle text-primary"></i> My Profile</h2>
      <p class="text-muted">Manage your personal information</p>
    </div>

    <div class="row g-4">

      <!-- ===== LEFT: PROFILE CARD ===== -->
      <div class="col-lg-4">
        <div class="profile-card">
          <div class="profile-avatar">
            <% if (user.profileImage) { %>
              <img src="<%= user.profileImage %>" alt="<%= user.name %>">
            <% } else { %>
              <div class="avatar-placeholder">
                <span><%= user.name.charAt(0).toUpperCase() %></span>
              </div>
            <% } %>
          </div>
          <h4 class="profile-name"><%= user.name %></h4>
          <p class="profile-email"><i class="fas fa-envelope"></i> <%= user.email %></p>
          <p class="profile-phone"><i class="fas fa-phone"></i> <%= user.phone %></p>
          
          <div class="profile-role">
            <span class="badge <%= user.role === 'provider' ? 'bg-primary' : 'bg-secondary' %>">
              <i class="fas <%= user.role === 'provider' ? 'fa-tools' : 'fa-user' %>"></i>
              <%= user.role.charAt(0).toUpperCase() + user.role.slice(1) %>
            </span>
          </div>

          <% if (user.role === 'provider') { %>
            <div class="provider-status mt-3">
              <div class="d-flex justify-content-between">
                <span class="text-muted">Verification Status</span>
                <span class="badge <%= user.providerProfile.verificationStatus === 'approved' ? 'bg-success' : user.providerProfile.verificationStatus === 'pending' ? 'bg-warning' : 'bg-danger' %>">
                  <%= user.providerProfile.verificationStatus || 'Pending' %>
                </span>
              </div>
            </div>
          <% } %>

          <div class="profile-stats mt-3">
            <div class="row g-2 text-center">
              <div class="col-4">
                <div class="stat-box">
                  <div class="stat-number"><%= bookings ? bookings.length : 0 %></div>
                  <div class="stat-label">Bookings</div>
                </div>
              </div>
              <div class="col-4">
                <div class="stat-box">
                  <div class="stat-number">
                    <% if (user.role === 'provider') { %>
                      <%= user.providerProfile.rating || 0 %>
                    <% } else { %>
                      -
                    <% } %>
                  </div>
                  <div class="stat-label">Rating</div>
                </div>
              </div>
              <div class="col-4">
                <div class="stat-box">
                  <div class="stat-number">
                    <% if (user.role === 'provider') { %>
                      <%= user.providerProfile.totalReviews || 0 %>
                    <% } else { %>
                      -
                    <% } %>
                  </div>
                  <div class="stat-label">Reviews</div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Quick Links -->
        <div class="profile-quick-links mt-3">
          <a href="/my-bookings" class="btn btn-outline-primary w-100 mb-2">
            <i class="fas fa-calendar-check"></i> My Bookings
          </a>
          <% if (user.role === 'provider') { %>
            <a href="/provider/dashboard" class="btn btn-outline-success w-100 mb-2">
              <i class="fas fa-tools"></i> Provider Dashboard
            </a>
          <% } %>
          <a href="/logout" class="btn btn-outline-danger w-100">
            <i class="fas fa-sign-out-alt"></i> Logout
          </a>
        </div>
      </div>

      <!-- ===== RIGHT: PROFILE FORM ===== -->
      <div class="col-lg-8">
        <div class="profile-form-card">
          <h5 class="mb-3"><i class="fas fa-edit text-primary"></i> Edit Profile</h5>

          <form action="/profile/update" method="POST" enctype="multipart/form-data">
            <div class="row g-3">
              <div class="col-md-6">
                <label class="form-label">Full Name</label>
                <input type="text" name="name" class="form-control" value="<%= user.name %>" required>
              </div>
              <div class="col-md-6">
                <label class="form-label">Email Address</label>
                <input type="email" name="email" class="form-control" value="<%= user.email %>" readonly>
              </div>
              <div class="col-md-6">
                <label class="form-label">Phone Number</label>
                <input type="tel" name="phone" class="form-control" value="<%= user.phone %>" required>
              </div>
              <div class="col-md-6">
                <label class="form-label">Profile Image</label>
                <input type="file" name="profileImage" class="form-control" accept="image/*">
              </div>
              <div class="col-12">
                <label class="form-label">Bio / About</label>
                <textarea name="bio" class="form-control" rows="3" placeholder="Tell us about yourself..."><%= user.bio || '' %></textarea>
              </div>
              <div class="col-12">
                <button type="submit" class="btn btn-primary">
                  <i class="fas fa-save"></i> Save Changes
                </button>
              </div>
            </div>
          </form>
        </div>

        <!-- ===== CHANGE PASSWORD ===== -->
        <div class="profile-form-card mt-3">
          <h5 class="mb-3"><i class="fas fa-lock text-warning"></i> Change Password</h5>

          <form action="/profile/change-password" method="POST">
            <div class="row g-3">
              <div class="col-md-4">
                <label class="form-label">Current Password</label>
                <input type="password" name="currentPassword" class="form-control" required>
              </div>
              <div class="col-md-4">
                <label class="form-label">New Password</label>
                <input type="password" name="newPassword" class="form-control" required minlength="6">
              </div>
              <div class="col-md-4">
                <label class="form-label">Confirm Password</label>
                <input type="password" name="confirmPassword" class="form-control" required>
              </div>
              <div class="col-12">
                <button type="submit" class="btn btn-warning">
                  <i class="fas fa-key"></i> Update Password
                </button>
              </div>
            </div>
          </form>
        </div>
      </div>

    </div>
  </div>
</div>

<!-- ============================================ -->
<!-- ===== STYLES ===== -->
<!-- ============================================ -->

<style>
  .profile-page {
    background: #f8f9fa;
    min-height: 100vh;
  }

  .profile-header h2 {
    font-weight: 700;
    color: #1a1a2e;
  }

  .profile-header p {
    color: #6c757d;
  }

  /* ===== PROFILE CARD ===== */
  .profile-card {
    background: white;
    border-radius: 16px;
    padding: 30px;
    text-align: center;
    box-shadow: 0 2px 20px rgba(0,0,0,0.06);
  }

  .profile-avatar {
    width: 120px;
    height: 120px;
    margin: 0 auto 15px;
    border-radius: 50%;
    overflow: hidden;
    border: 4px solid #007bff;
  }

  .profile-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .avatar-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #007bff, #0056b3);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 3rem;
    font-weight: 700;
  }

  .profile-name {
    font-weight: 700;
    font-size: 1.3rem;
    margin-bottom: 4px;
  }

  .profile-email,
  .profile-phone {
    color: #6c757d;
    font-size: 0.9rem;
    margin-bottom: 4px;
  }

  .profile-email i,
  .profile-phone i {
    margin-right: 6px;
    width: 18px;
  }

  .profile-role .badge {
    padding: 6px 18px;
    font-size: 14px;
    border-radius: 30px;
  }

  .profile-stats {
    border-top: 1px solid #e9ecef;
    padding-top: 15px;
  }

  .stat-box .stat-number {
    font-size: 1.5rem;
    font-weight: 700;
    color: #1a1a2e;
  }

  .stat-box .stat-label {
    font-size: 12px;
    color: #6c757d;
  }

  .provider-status {
    background: #f8f9fa;
    padding: 10px 15px;
    border-radius: 8px;
  }

  /* ===== PROFILE FORM ===== */
  .profile-form-card {
    background: white;
    border-radius: 16px;
    padding: 25px;
    box-shadow: 0 2px 20px rgba(0,0,0,0.06);
  }

  .profile-form-card h5 {
    color: #1a1a2e;
  }

  .form-label {
    font-weight: 500;
    font-size: 14px;
    color: #495057;
  }

  .form-control {
    border: 2px solid #e0e0e0;
    border-radius: 8px;
    padding: 10px 14px;
    transition: all 0.3s;
  }

  .form-control:focus {
    border-color: #007bff;
    box-shadow: 0 0 0 3px rgba(0,123,255,0.15);
  }

  .form-control:disabled {
    background: #e9ecef;
  }

  .btn-primary {
    background: #007bff;
    border: none;
    padding: 10px 30px;
    border-radius: 8px;
    font-weight: 600;
    transition: all 0.3s;
  }

  .btn-primary:hover {
    background: #0056b3;
    transform: translateY(-2px);
    box-shadow: 0 4px 15px rgba(0,123,255,0.3);
  }

  .btn-warning {
    border: none;
    padding: 10px 30px;
    border-radius: 8px;
    font-weight: 600;
    transition: all 0.3s;
  }

  .btn-warning:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 15px rgba(255,193,7,0.3);
  }

  .btn-outline-primary,
  .btn-outline-success,
  .btn-outline-danger {
    padding: 10px;
    border-radius: 8px;
    font-weight: 600;
    transition: all 0.3s;
  }

  .btn-outline-primary:hover {
    background: #007bff;
    color: white;
  }

  .btn-outline-success:hover {
    background: #28a745;
    color: white;
  }

  .btn-outline-danger:hover {
    background: #dc3545;
    color: white;
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 992px) {
    .profile-card {
      padding: 20px;
    }

    .profile-avatar {
      width: 100px;
      height: 100px;
    }

    .avatar-placeholder {
      font-size: 2.5rem;
    }
  }

  @media (max-width: 768px) {
    .profile-page {
      padding: 10px;
    }

    .profile-card {
      padding: 15px;
    }

    .profile-avatar {
      width: 80px;
      height: 80px;
    }

    .avatar-placeholder {
      font-size: 2rem;
    }

    .profile-form-card {
      padding: 15px;
    }

    .profile-form-card .row .col-md-4 {
      margin-bottom: 10px;
    }
  }

  @media (max-width: 576px) {
    .profile-header h2 {
      font-size: 1.5rem;
    }

    .profile-avatar {
      width: 70px;
      height: 70px;
    }

    .avatar-placeholder {
      font-size: 1.5rem;
    }

    .profile-name {
      font-size: 1.1rem;
    }

    .stat-box .stat-number {
      font-size: 1.2rem;
    }

    .profile-quick-links .btn {
      font-size: 14px;
    }
  }
</style>