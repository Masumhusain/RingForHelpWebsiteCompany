<%- layout("/layouts/boilerplate.ejs") %>

<div class="admin-page">
  <div class="container py-4">

    <!-- Page Header -->
    <div class="admin-header mb-4">
      <div class="d-flex justify-content-between align-items-center flex-wrap">
        <div>
          <h2><i class="fas fa-user-check text-primary"></i> Manage Providers</h2>
          <p class="text-muted">View and verify service providers</p>
        </div>
        <a href="/admin/dashboard" class="btn btn-outline-secondary mt-2 mt-sm-0">
          <i class="fas fa-arrow-left"></i> Back to Dashboard
        </a>
      </div>
    </div>

    <!-- Stats Cards -->
    <div class="row mb-4">
      <div class="col-md-3 col-6">
        <div class="stat-card">
          <div class="stat-icon bg-primary">
            <i class="fas fa-users"></i>
          </div>
          <div class="stat-info">
            <h5><%= providers ? providers.length : 0 %></h5>
            <p>Total Providers</p>
          </div>
        </div>
      </div>
      <div class="col-md-3 col-6">
        <div class="stat-card">
          <div class="stat-icon bg-warning">
            <i class="fas fa-clock"></i>
          </div>
          <div class="stat-info">
            <h5><%= providers ? providers.filter(p => p.providerProfile && p.providerProfile.verificationStatus === 'pending').length : 0 %></h5>
            <p>Pending</p>
          </div>
        </div>
      </div>
      <div class="col-md-3 col-6">
        <div class="stat-card">
          <div class="stat-icon bg-success">
            <i class="fas fa-check-circle"></i>
          </div>
          <div class="stat-info">
            <h5><%= providers ? providers.filter(p => p.providerProfile && p.providerProfile.verificationStatus === 'approved').length : 0 %></h5>
            <p>Approved</p>
          </div>
        </div>
      </div>
      <div class="col-md-3 col-6">
        <div class="stat-card">
          <div class="stat-icon bg-danger">
            <i class="fas fa-times-circle"></i>
          </div>
          <div class="stat-info">
            <h5><%= providers ? providers.filter(p => p.providerProfile && p.providerProfile.verificationStatus === 'rejected').length : 0 %></h5>
            <p>Rejected</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Filter Buttons -->
    <div class="mb-3">
      <button class="btn btn-sm btn-outline-primary filter-btn active" data-filter="all">All</button>
      <button class="btn btn-sm btn-outline-warning filter-btn" data-filter="pending">Pending</button>
      <button class="btn btn-sm btn-outline-success filter-btn" data-filter="approved">Approved</button>
      <button class="btn btn-sm btn-outline-danger filter-btn" data-filter="rejected">Rejected</button>
    </div>

    <!-- Providers Table -->
    <div class="table-card">
      <div class="table-responsive">
        <table class="table table-hover" id="providersTable">
          <thead>
            <tr>
              <th>#</th>
              <th>Profile</th>
              <th>Name</th>
              <th>Company</th>
              <th>Email</th>
              <th>Phone</th>
              <th>Status</th>
              <th>Joined</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% if (providers && providers.length > 0) { %>
              <% providers.forEach(function(provider, index) { %>
                <tr class="provider-row" data-status="<%= provider.providerProfile && provider.providerProfile.verificationStatus || 'pending' %>">
                  <td><%= index + 1 %></td>
                  <td>
                    <% if (provider.providerProfile && provider.providerProfile.profileImage) { %>
                      <img src="<%= provider.providerProfile.profileImage %>" alt="Profile" class="profile-img" onerror="this.src='/images/default-avatar.png'">
                    <% } else { %>
                      <div class="profile-placeholder"><%= provider.name ? provider.name.charAt(0).toUpperCase() : 'U' %></div>
                    <% } %>
                  </td>
                  <td><strong><%= provider.name || 'N/A' %></strong></td>
                  <td><%= provider.providerProfile && provider.providerProfile.companyName || 'N/A' %></td>
                  <td><%= provider.email || 'N/A' %></td>
                  <td><%= provider.phone || 'N/A' %></td>
                  <td>
                    <% const status = provider.providerProfile && provider.providerProfile.verificationStatus || 'pending'; %>
                    <span class="badge <%= status === 'approved' ? 'bg-success' : status === 'pending' ? 'bg-warning text-dark' : 'bg-danger' %>">
                      <i class="fas <%= status === 'approved' ? 'fa-check-circle' : status === 'pending' ? 'fa-clock' : 'fa-times-circle' %>"></i>
                      <%= status.charAt(0).toUpperCase() + status.slice(1) %>
                    </span>
                  </td>
                  <td><%= provider.createdAt ? new Date(provider.createdAt).toLocaleDateString('en-IN') : 'N/A' %></td>
                  <td>
                    <div class="btn-group btn-group-sm">
                      <!-- View Details -->
                      <button class="btn btn-info view-provider" data-id="<%= provider._id %>" title="View Details">
                        <i class="fas fa-eye"></i>
                      </button>
                      
                      <!-- Verify/Reject buttons -->
                      <% if (status !== 'approved') { %>
                        <button class="btn btn-success verify-provider" data-id="<%= provider._id %>" data-status="approved" title="Approve">
                          <i class="fas fa-check"></i>
                        </button>
                      <% } %>
                      <% if (status !== 'rejected') { %>
                        <button class="btn btn-danger verify-provider" data-id="<%= provider._id %>" data-status="rejected" title="Reject">
                          <i class="fas fa-times"></i>
                        </button>
                      <% } %>
                      
                      <!-- Delete -->
                      <button class="btn btn-dark delete-provider" data-id="<%= provider._id %>" title="Delete">
                        <i class="fas fa-trash"></i>
                      </button>
                    </div>
                  </td>
                </tr>
              <% }); %>
            <% } else { %>
              <tr>
                <td colspan="9" class="text-center py-4">
                  <i class="fas fa-users fa-2x text-muted d-block mb-2"></i>
                  No providers found
                </td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>

  </div>
</div>

<!-- ===== VIEW PROVIDER MODAL ===== -->
<div class="modal fade" id="viewProviderModal" tabindex="-1">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Provider Details</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body" id="providerDetails">
        <div class="text-center py-4">
          <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- ============================================ -->
<!-- ===== STYLES ===== -->
<!-- ============================================ -->

<style>
  .admin-page {
    background: #f8f9fa;
    min-height: 100vh;
  }

  .admin-header h2 {
    font-weight: 700;
    color: #1a1a2e;
  }

  /* Stats Cards */
  .stat-card {
    background: white;
    padding: 15px;
    border-radius: 12px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.06);
    display: flex;
    align-items: center;
    gap: 15px;
    transition: transform 0.3s ease;
  }

  .stat-card:hover {
    transform: translateY(-3px);
  }

  .stat-icon {
    width: 50px;
    height: 50px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-size: 20px;
  }

  .stat-icon.bg-primary { background: #4a6cf7; }
  .stat-icon.bg-warning { background: #ffc107; }
  .stat-icon.bg-success { background: #28a745; }
  .stat-icon.bg-danger { background: #dc3545; }

  .stat-info h5 {
    margin: 0;
    font-weight: 700;
    font-size: 20px;
    color: #1a1a2e;
  }

  .stat-info p {
    margin: 0;
    font-size: 13px;
    color: #6c757d;
  }

  /* Table Card */
  .table-card {
    background: white;
    padding: 20px;
    border-radius: 12px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.06);
  }

  .table th {
    font-weight: 600;
    color: #495057;
    border-bottom: 2px solid #e9ecef;
    font-size: 13px;
  }

  .table td {
    vertical-align: middle;
    font-size: 14px;
  }

  /* Profile Image */
  .profile-img {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid #e9ecef;
  }

  .profile-placeholder {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: #4a6cf7;
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 18px;
  }

  .badge {
    padding: 5px 12px;
    border-radius: 20px;
    font-size: 12px;
    font-weight: 500;
  }

  .btn-group .btn {
    padding: 5px 10px;
    border-radius: 4px;
    font-size: 13px;
  }

  /* Filter Buttons */
  .filter-btn {
    margin-right: 5px;
    border-radius: 20px;
    padding: 5px 15px;
  }

  .filter-btn.active {
    background: #4a6cf7;
    color: white;
    border-color: #4a6cf7;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .table-card {
      padding: 10px;
    }
    
    .stat-card {
      padding: 10px;
    }
    
    .stat-icon {
      width: 40px;
      height: 40px;
      font-size: 16px;
    }
    
    .stat-info h5 {
      font-size: 16px;
    }
    
    .table td, .table th {
      font-size: 12px;
      padding: 8px 5px;
    }
  }
</style>

<!-- ============================================ -->
<!-- ===== SCRIPTS ===== -->
<!-- ============================================ -->

<script>
  document.addEventListener('DOMContentLoaded', function() {
    
    // ===== FILTER PROVIDERS =====
    const filterButtons = document.querySelectorAll('.filter-btn');
    const providerRows = document.querySelectorAll('.provider-row');
    
    filterButtons.forEach(function(btn) {
      btn.addEventListener('click', function() {
        // Remove active class from all
        filterButtons.forEach(function(b) { b.classList.remove('active'); });
        this.classList.add('active');
        
        const filter = this.dataset.filter;
        
        providerRows.forEach(function(row) {
          if (filter === 'all') {
            row.style.display = '';
          } else {
            const status = row.dataset.status;
            row.style.display = status === filter ? '' : 'none';
          }
        });
      });
    });

    // ===== VERIFY PROVIDER =====
    document.querySelectorAll('.verify-provider').forEach(function(btn) {
      btn.addEventListener('click', function() {
        const providerId = this.dataset.id;
        const status = this.dataset.status;
        const action = status === 'approved' ? 'approve' : 'reject';
        
        if (confirm('Are you sure you want to ' + action + ' this provider?')) {
          fetch('/admin/providers/' + providerId + '/verify', {
            method: 'PUT',
            headers: {
              'Content-Type': 'application/json'
            },
            body: JSON.stringify({ status: status })
          })
          .then(function(response) { 
            if (!response.ok) {
              throw new Error('Network response was not ok');
            }
            return response.json(); 
          })
          .then(function(data) {
            if (data.success) {
              location.reload();
            } else {
              alert('Failed to verify provider: ' + (data.message || 'Unknown error'));
            }
          })
          .catch(function(err) {
            console.error('Error:', err);
            alert('Error verifying provider. Please try again.');
          });
        }
      });
    });

    // ===== DELETE PROVIDER =====
    document.querySelectorAll('.delete-provider').forEach(function(btn) {
      btn.addEventListener('click', function() {
        const providerId = this.dataset.id;
        if (confirm('⚠️ Are you sure you want to delete this provider? This action cannot be undone!')) {
          fetch('/admin/providers/' + providerId, {
            method: 'DELETE'
          })
          .then(function(response) { 
            if (!response.ok) {
              throw new Error('Network response was not ok');
            }
            return response.json(); 
          })
          .then(function(data) {
            if (data.success) {
              location.reload();
            } else {
              alert('Failed to delete provider: ' + (data.message || 'Unknown error'));
            }
          })
          .catch(function(err) {
            console.error('Error:', err);
            alert('Error deleting provider. Please try again.');
          });
        }
      });
    });

    // ===== VIEW PROVIDER DETAILS =====
    document.querySelectorAll('.view-provider').forEach(function(btn) {
      btn.addEventListener('click', function() {
        const providerId = this.dataset.id;
        const modal = new bootstrap.Modal(document.getElementById('viewProviderModal'));
        const detailsDiv = document.getElementById('providerDetails');
        
        // Show loading
        detailsDiv.innerHTML = `
          <div class="text-center py-4">
            <div class="spinner-border text-primary" role="status">
              <span class="visually-hidden">Loading...</span>
            </div>
          </div>
        `;
        
        modal.show();
        
        // Fetch provider details
        fetch('/admin/providers/' + providerId)
          .then(function(response) { return response.json(); })
          .then(function(data) {
            if (data.success) {
              const p = data.provider;
              detailsDiv.innerHTML = `
                <div class="row">
                  <div class="col-md-4 text-center">
                    <img src="${p.providerProfile && p.providerProfile.profileImage || '/images/default-avatar.png'}" 
                         class="img-fluid rounded-circle mb-3" style="width:150px;height:150px;object-fit:cover;">
                    <h5>${p.name}</h5>
                    <p class="text-muted">${p.email}</p>
                    <span class="badge ${p.providerProfile && p.providerProfile.verificationStatus === 'approved' ? 'bg-success' : 'bg-warning'}">
                      ${p.providerProfile && p.providerProfile.verificationStatus || 'Pending'}
                    </span>
                  </div>
                  <div class="col-md-8">
                    <div class="row">
                      <div class="col-6">
                        <strong>Company:</strong>
                        <p>${p.providerProfile && p.providerProfile.companyName || 'N/A'}</p>
                      </div>
                      <div class="col-6">
                        <strong>Business Type:</strong>
                        <p>${p.providerProfile && p.providerProfile.businessType || 'N/A'}</p>
                      </div>
                      <div class="col-6">
                        <strong>Hourly Rate:</strong>
                        <p>₹${p.providerProfile && p.providerProfile.hourlyRate || 0}</p>
                      </div>
                      <div class="col-6">
                        <strong>Service Radius:</strong>
                        <p>${p.providerProfile && p.providerProfile.serviceRadius || 0} km</p>
                      </div>
                      <div class="col-12">
                        <strong>Address:</strong>
                        <p>${p.providerProfile && p.providerProfile.address ? 
                          `${p.providerProfile.address.street || ''}, ${p.providerProfile.address.city || ''}, ${p.providerProfile.address.state || ''} - ${p.providerProfile.address.pincode || ''}` 
                          : 'N/A'}</p>
                      </div>
                    </div>
                  </div>
                </div>
              `;
            } else {
              detailsDiv.innerHTML = `<div class="alert alert-danger">${data.message || 'Error loading provider details'}</div>`;
            }
          })
          .catch(function(err) {
            console.error('Error:', err);
            detailsDiv.innerHTML = `<div class="alert alert-danger">Error loading provider details</div>`;
          });
      });
    });

  });
</script>