<%- layout("/layouts/boilerplate.ejs") %>

<div class="success-page text-center py-5">
  <div class="container">
    <div style="font-size: 80px; color: #28a745;">
      <i class="fas fa-check-circle"></i>
    </div>
    <h2 class="mt-3">Order Placed Successfully! 🎉</h2>
    <p class="text-muted"><%= bookingCount %> service(s) booked successfully</p>
    
    <div class="success-details mt-4">
      <h5>Booking Summary</h5>
      <div class="row justify-content-center">
        <% bookings.forEach((booking, index) => { %>
          <div class="col-md-4">
            <div class="booking-card">
              <h6><%= booking.serviceName %></h6>
              <p>
                <strong>Date:</strong> <%= booking.date %><br>
                <strong>Time:</strong> <%= booking.time %><br>
                <strong>Duration:</strong> <%= booking.duration %> hr(s)<br>
                <strong>Quantity:</strong> <%= booking.quantity %><br>
                <strong>Total:</strong> ₹<%= booking.totalAmount %><br>
                <strong>Status:</strong> 
                <span class="badge badge-warning"><%= booking.status %></span>
              </p>
            </div>
          </div>
        <% }) %>
      </div>
      
      <div class="mt-4">
        <p><strong>Total Amount: ₹<%= totalAmount %></strong></p>
      </div>
      
      <div class="mt-4">
        <a href="/my-bookings" class="btn btn-primary">View My Bookings</a>
        <a href="/" class="btn btn-secondary">Go Home</a>
      </div>
    </div>
  </div>
</div>

<style>
  .success-page {
    padding: 40px 0;
  }
  
  .booking-card {
    background: white;
    padding: 18px;
    border-radius: 10px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.06);
    margin: 10px 0;
    text-align: left;
  }
  
  .booking-card h6 {
    color: #007bff;
    margin-bottom: 10px;
  }
  
  .badge-warning {
    background: #ffc107;
    padding: 4px 12px;
    border-radius: 20px;
    font-size: 12px;
  }
</style>