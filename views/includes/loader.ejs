<!-- views/includes/loader-spinner.ejs -->
<div id="global-loader" style="display: none;">
    <div class="loader-overlay">
        <div class="loader-container">
            <!-- Spinner Loader -->
            <div class="spinner-loader">
                <div class="spinner-ring">
                    <div class="spinner-segment"></div>
                    <div class="spinner-segment"></div>
                    <div class="spinner-segment"></div>
                    <div class="spinner-segment"></div>
                    <div class="spinner-segment"></div>
                    <div class="spinner-segment"></div>
                    <div class="spinner-segment"></div>
                    <div class="spinner-segment"></div>
                </div>
                <div class="spinner-icon">⚡</div>
            </div>
            <p class="loader-text">Please wait</p>
        </div>
    </div>
</div>

<style>
    #global-loader {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        z-index: 9999;
        display: none;
        pointer-events: none;
    }
    
    .loader-overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(255, 255, 255, 0.75);
        backdrop-filter: blur(3px);
        display: flex;
        justify-content: center;
        align-items: center;
        pointer-events: none;
    }
    
    .loader-container {
        text-align: center;
        padding: 15px;
        pointer-events: none;
    }
    
    /* ===== SPINNER LOADER - 65px ===== */
    .spinner-loader {
        position: relative;
        width: 65px;
        height: 65px;
        margin: 0 auto 10px;
    }
    
    .spinner-ring {
        position: absolute;
        width: 100%;
        height: 100%;
        animation: spin 1.2s linear infinite;
    }
    
    @keyframes spin {
        0% { transform: rotate(0deg); }
        100% { transform: rotate(360deg); }
    }
    
    .spinner-segment {
        position: absolute;
        width: 6px;
        height: 18px;
        background: #667eea;
        border-radius: 3px;
        top: 0;
        left: 50%;
        transform: translateX(-50%) rotate(0deg);
        opacity: 0.2;
    }
    
    .spinner-segment:nth-child(1) { transform: translateX(-50%) rotate(0deg); opacity: 1; }
    .spinner-segment:nth-child(2) { transform: translateX(-50%) rotate(45deg); opacity: 0.8; }
    .spinner-segment:nth-child(3) { transform: translateX(-50%) rotate(90deg); opacity: 0.6; }
    .spinner-segment:nth-child(4) { transform: translateX(-50%) rotate(135deg); opacity: 0.4; }
    .spinner-segment:nth-child(5) { transform: translateX(-50%) rotate(180deg); opacity: 0.3; }
    .spinner-segment:nth-child(6) { transform: translateX(-50%) rotate(225deg); opacity: 0.2; }
    .spinner-segment:nth-child(7) { transform: translateX(-50%) rotate(270deg); opacity: 0.15; }
    .spinner-segment:nth-child(8) { transform: translateX(-50%) rotate(315deg); opacity: 0.1; }
    
    .spinner-icon {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        font-size: 20px;
        animation: iconPulse 1.5s ease-in-out infinite;
    }
    
    @keyframes iconPulse {
        0%, 100% { transform: translate(-50%, -50%) scale(1); }
        50% { transform: translate(-50%, -50%) scale(1.2); }
    }
    
    .loader-text {
        font-size: 11px;
        color: #999;
        font-weight: 400;
        letter-spacing: 1px;
        margin: 0;
    }
</style>